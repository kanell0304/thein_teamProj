### 개발용 로그인 (실제 카카오 인증 없이 토큰 발급)
# 이 요청을 먼저 실행하면 이후 recommendation-flow.http / recommendation-scenarios.http의
# 요청들이 자동으로 이 토큰을 Authorization 헤더에 실어 보낼 수 있도록 전역 변수에 저장한다.
POST http://localhost:8081/api/dev/auth/login
Content-Type: application/json

{
  "kakaoId": "dev-test-1",
  "nickname": "테스터"
}

> {%
    client.test("토큰 발급 확인", function () {
        client.assert(response.body.accessToken, "accessToken이 있어야 함");
    });
    client.global.set("authToken", response.body.accessToken);
    client.global.set("memberId", response.body.memberId);
%}

### (참고) 다른 kakaoId로 로그인하면 별도 회원이 생성된다
POST http://localhost:8081/api/dev/auth/login
Content-Type: application/json

{
  "kakaoId": "dev-test-2",
  "nickname": "테스터2"
}
