# backend/.env 로 복사해서 실제 값을 채우세요. .env 자체는 .gitignore에 의해 커밋되지 않습니다.
OPENAI_API_KEY=
# 카카오 개발자 콘솔 > 내 애플리케이션 > 앱 키 > REST API 키
KAKAO_REST_API_KEY=
# JWT 서명 키. 로컬에서는 `openssl rand -base64 48` 로 생성해서 채우세요.
JWT_SECRET=
# 구글 클라우드 콘솔 > API 및 서비스 > 사용자 인증 정보 (Places API (New) 활성화 필요). 없으면 카카오 이미지 검색으로 자동 폴백됨.
GOOGLE_PLACES_API_KEY=
